{
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.0"
  },
  "name": "codex-quality-gate-dashboard",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "build": "tsc -b && vite build",
    "desktop": "electron electron/main.cjs",
    "desktop:package": "electron-builder --win portable",
    "lint": "eslint .",
    "test": "node --test test/*.test.mjs",
    "typecheck": "tsc -b --noEmit"
  },
  "type": "module",
  "version": "0.1.1",
  "build": {
    "appId": "io.codex-quality-gate.desktop",
    "productName": "codex-quality-gate",
    "asar": true,
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "desktop-backend",
        "to": "desktop-backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "packElevateHelper": false
    }
  }
}
